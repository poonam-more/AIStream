// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and must not be committed.

// AI provider: mock | openai | gemini
AI_PROVIDER = mock

// API keys (only required when AI_PROVIDER is openai or gemini)
// Do NOT wrap values in quotes — xcconfig includes quotes literally.
OPENAI_API_KEY =
GEMINI_API_KEY =

// Optional custom backend base URL (leave empty to use mock services)
API_BASE_URL =

// OpenAI model override (optional)
OPENAI_MODEL = gpt-4o-mini

// Gemini model override (optional)
GEMINI_MODEL = gemini-2.0-flash
